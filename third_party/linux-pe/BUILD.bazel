load("@rules_cc//cc:defs.bzl", "cc_library")

package(default_visibility = ["//visibility:public"])

# linux-pe is a header-only library
cc_library(
    name = "linux_pe",
    hdrs = glob(["includes/**/*.hpp"], allow_empty = True) + 
           glob(["includes/**/linuxpe"], allow_empty = True) + 
           glob(["includes/**/*.h"], allow_empty = True),
    includes = ["includes"],
)
